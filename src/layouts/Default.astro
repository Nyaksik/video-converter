---
import '@/styles/global.css'
import 'vue-sonner/style.css'
import { SEO } from 'astro-seo'
import { Schema } from 'astro-seo-schema'
import { PUBLIC_METRIKA, PUBLIC_SITE_NAME } from 'astro:env/server'

import PageFooter from '@/components/PageFooter.astro'
import PageHeader from '@/components/PageHeader.astro'
import { Toaster } from '@/components/ui/sonner'
import { getLangFromUrl } from '@/i18n'

import type { Thing, WithContext } from 'schema-dts'

interface Props {
  description: string
  keywords: string
  schema?: WithContext<Thing> | WithContext<Thing>[]
  title: string
}

const {
  title, description, keywords, schema,
} = Astro.props
const lang = getLangFromUrl(Astro.url)
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const fullTitle = `${title} | ${PUBLIC_SITE_NAME}`
const canonicalUrl = Astro.url.href
const pagePath = Astro.url.pathname.replace(/^\//, '').replace(/\/$/, '') || 'index'
const ogImage = new URL(`/og/${pagePath}.png`, Astro.site).href

const metrikaScript = `
 <!-- Yandex.Metrika counter --> <script type="text/javascript">     (function(m,e,t,r,i,k,a){         m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};         m[i].l=1*new Date();         for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}         k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)     })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=106622925', 'ym');      ym(106622925, 'init', {ssr:true, trackHash:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true}); </script> <noscript><div><img src="https://mc.yandex.ru/watch/106622925" style="position:absolute; left:-9999px;" alt="" /></div></noscript> <!-- /Yandex.Metrika counter -->   
`;
---

<html lang={lang}>
  <head>
    <SEO
      title={fullTitle}
      description={description}
      openGraph={{
        basic: {
          title: fullTitle,
          type: 'website',
          image: ogImage,
          url: canonicalUrl,
        },
        optional: {
          description,
          locale: lang,
          siteName: PUBLIC_SITE_NAME,
        },
        image: {
          alt: PUBLIC_SITE_NAME,
          width: 1200,
          height: 630,
          type: 'image/png',
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title: fullTitle,
        description,
        image: ogImage,
        imageAlt: PUBLIC_SITE_NAME,
      }}
    />
    <meta charset="utf-8" />
    <link rel="sitemap" href={`${base}/sitemap-index.xml`} />
    <link rel="manifest" href={`${base}/manifest.webmanifest`} >
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="icon" href={`${base}/favicon.ico`} />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700&family=JetBrains+Mono:wght@400;500&family=Manrope:wght@400;600&display=swap" rel="stylesheet" >
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="keywords" content={keywords} />

    <script define:vars={{ base }}>
      const theme = localStorage.getItem('theme')
      const prefersDark = matchMedia('(prefers-color-scheme: dark)').matches

      if (theme === 'dark' || (!theme && prefersDark)) {
        document.documentElement.classList.add('dark')
      }

      if (!localStorage.getItem('locale')) {
        const browserLang = navigator.language.slice(0, 2)
        const localPath = location.pathname.slice(base.length)
        const isRuPage = !localPath.startsWith('/en')

        if (browserLang !== 'ru' && isRuPage) {
          localStorage.setItem('locale', 'en')
          location.replace(base + '/en' + localPath)
        }
        else {
          localStorage.setItem('locale', 'ru')
        }
      }
    </script>

    {schema && (Array.isArray(schema)
      ? schema.map(s => <Schema item={s} />)
      : <Schema item={schema} />
    )}
    {PUBLIC_METRIKA && <Fragment set:html={metrikaScript} />}
  </head>
  <body class="flex flex-col min-h-dvh">
    <PageHeader />
    <main class="grow">
      <slot></slot>
    </main>
    <PageFooter />
    <Toaster client:only="vue" />
  </body>
</html>
