---
import Badge from '@/components/ui/badge/Badge.vue'
import Button from '@/components/ui/button/Button.vue'
import { useTranslations } from '@/i18n'
import Default from '@/layouts/Default.astro'

const t = useTranslations('en')
---

<Default title={t('home.pageTitle')}>
  <section class="container py-[5%] max-w-[800px]">
    <h1 class="text-6xl lg:text-7xl font-bold mb-5 text-center">
      {t('home.title')}
    </h1>
    <div class="flex flex-wrap gap-1 justify-center items-center mb-8">
      <Badge variant="secondary">
        {t('home.badge.noWatermarks')}
      </Badge>
      <Badge variant="secondary">
        {t('home.badge.noUpload')}
      </Badge>
      <Badge variant="secondary">
        {t('home.badge.free')}
      </Badge>
      <Badge variant="secondary">
        {t('home.badge.savings')}
      </Badge>
    </div>
    <div class="flex justify-center">
      <Button as="a" href="/en/compressor" size="lg" class="text-2xl px-12 h-16">
        {t('home.cta')}
      </Button>
    </div>
  </section>
</Default>
